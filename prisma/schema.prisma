// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  STAFF
  ADMIN
  SUPER_ADMIN
}

enum ProductBadge {
  NEW
  BEST_SELLER
  LIMITED
  TRENDING
  COLLECTOR_PICK
}

enum LoyaltyTransactionType {
  EARNED
  REDEEMED
  ADJUSTED
  EXPIRED
}

model User {
  id               String               @id @default(uuid())
  email            String               @unique
  password         String?
  name             String?
  phone            String?
  avatar           String?
  role             Role                 @default(CUSTOMER)
  emailVerified    Boolean              @default(false)
  lastLogin        DateTime?
  isBlocked        Boolean              @default(false)
  marketingConsent Boolean              @default(false)
  loyaltyPoints    Int                  @default(0)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  
  orders           Order[]
  reviews          Review[]
  wishlists        Wishlist[]
  addresses        Address[]
  loyaltyHistory   LoyaltyTransaction[]

  @@map("users")
}

model Address {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           String   @default("Home") // Home, Office, Gift, etc.
  name           String
  street         String
  city           String
  state          String?
  zip            String
  country        String   @default("India")
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("addresses")
}

model Product {
  id                  String         @id @default(uuid())
  slug                String         @unique
  title               String
  film                String
  year                Int
  director            String
  cast                String[]
  collectionName      String
  collection          Collection     @relation(fields: [collectionName], references: [name])
  genre               String
  price               Float
  inventory           Int            @default(0)
  lowStockThreshold   Int            @default(5)
  isPreorder          Boolean        @default(false)
  isSoldOut           Boolean        @default(false)
  limitedEditionCount Int?
  
  // Polacraft v1.1 Limited Edition & Badge Fields
  badge               ProductBadge?
  isLimitedEdition    Boolean        @default(false)
  editionTotal        Int?           @default(100)
  editionSold         Int?           @default(0)

  // Custom flags
  featured            Boolean        @default(false)
  newArrival          Boolean        @default(false)
  bestSeller          Boolean        @default(false)
  featuredOrder       Int            @default(0)
  averageRating       Float          @default(0.0)
  reviewCount         Int            @default(0)

  // Palette settings
  primaryColor        String
  accentColor         String
  bgColor             String
  textColor           String

  gsm                 Int            @default(250)
  finish              String         @default("Ultra-Matte Giclée")
  paperType           String         @default("Fine Art Cotton Archival")
  
  tagline             String
  story               String         @db.Text
  designNotes         String         @db.Text

  // Polacraft v1.2 AI Product Assistant Fields
  aiGenerated         Boolean?       @default(false)
  aiGeneratedAt       DateTime?
  aiReviewedByAdmin   Boolean?       @default(false)

  images              ProductImage[]
  reviews             Review[]
  orderItems          OrderItem[]
  wishlistedBy        Wishlist[]
  
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  publishedAt         DateTime?

  @@index([collectionName])
  @@index([createdAt])
  @@index([featured])
  @@map("products")
}

model ProductImage {
  id        String    @id @default(uuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  publicId  String?
  alt       String
  sortOrder Int       @default(0)
  type      ImageType @default(GALLERY) // HERO, GALLERY, WALL_MOCKUP, PACKAGING, DETAIL, MOBILE

  @@map("product_images")
}

enum ImageType {
  HERO
  GALLERY
  WALL_MOCKUP
  PACKAGING
  DETAIL
  MOBILE
}

model Collection {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())

  @@map("collections")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@map("wishlists")
}

model Review {
  id               String   @id @default(uuid())
  productId        String
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId           String?
  user             User?    @relation(fields: [userId], references: [id])
  userName         String
  rating           Int
  title            String?
  comment          String   @db.Text
  images           String[]
  adminReply       String?  @db.Text
  helpfulCount     Int      @default(0)
  verifiedPurchase Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@map("reviews")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  size      String
  frame     String
  price     Float
  quantity  Int

  @@map("order_items")
}

model OrderReward {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rewardType   String   // "COLLECTOR" | "PREMIUM"
  rewardOption String   // e.g., "1xA3", "2xA4", "4xA5", "1xA4_2xA5"
  quantity     Int      @default(1)
  estimatedCost Float   @default(0.0)
  createdAt    DateTime @default(now())

  @@map("order_rewards")
}

model Order {
  id                 String                @id @default(uuid())
  orderNumber        String                @unique
  userId             String?
  user               User?                 @relation(fields: [userId], references: [id])
  email              String
  phone              String?
  
  // Shipping details
  shippingName       String
  shippingStreet     String
  shippingCity       String
  shippingState      String?
  shippingZip        String
  shippingCountry    String

  items              OrderItem[]
  rewards            OrderReward[]
  subtotal           Float
  shippingCost       Float
  taxAmount          Float                 @default(0.0)
  discount           Float
  total              Float
  
  paymentMethod      String
  paymentReference   String?
  upiTransactionId   String?
  paymentProofImage  String?
  paymentStatus      PaymentStatus         @default(PENDING)
  shippingStatus     ShippingStatus        @default(PENDING)
  paymentVerifiedAt  DateTime?
  inventoryDeductedAt DateTime?
  confirmedByAdminId String?
  trackingNumber     String?
  estimatedDelivery  DateTime?
  notes              String?               @db.Text
  
  statusHistory      OrderStatusHistory[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([paymentStatus])
  @@index([shippingStatus])
  @@index([createdAt])
  @@index([userId])
  @@map("orders")
}

model OrderStatusHistory {
  id        String         @id @default(uuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    ShippingStatus
  comment   String?
  createdAt DateTime       @default(now())

  @@map("order_status_histories")
}

enum PaymentStatus {
  PENDING
  VERIFIED
  PAID
  FAILED
}

enum ShippingStatus {
  WHATSAPP_PENDING
  PENDING
  CONFIRMED
  PAID
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  RETURNED
  CANCELLED
  EXPIRED
}

model Coupon {
  id           String       @id @default(uuid())
  code         String       @unique
  discountType DiscountType @default(percentage)
  value        Float
  active       Boolean      @default(true)
  expiryDate   DateTime?
  createdAt    DateTime     @default(now())

  @@map("coupons")
}

enum DiscountType {
  percentage
  fixed
}

model NewsletterSubscriber {
  id           String   @id @default(uuid())
  email        String   @unique
  subscribedAt DateTime @default(now())
  isActive     Boolean  @default(true)

  @@map("newsletter_subscribers")
}

model Testimonial {
  id        String   @id @default(uuid())
  quote     String   @db.Text
  author    String
  rating    String   @default("★★★★★")
  createdAt DateTime @default(now())

  @@map("testimonials")
}

model SiteSettings {
  id                       String   @id @default(uuid())
  shippingFee              Float    @default(60.0)
  freeShippingThreshold    Float    @default(499.0)
  collectorRewardThreshold Float    @default(899.0)
  premiumRewardThreshold   Float    @default(1499.0)
  loyaltyPointsRatio       Float    @default(100.0)
  heroTitle                String   @default("Bring Cinema Home.")
  heroSubtitle             String   @default("Premium Malayalam Cinema Posters Crafted For Collectors.")
  rewardsEnabled           Boolean  @default(true)
  limitedEditionsEnabled   Boolean  @default(true)
  instagramUrl             String?
  logo                     String?
  supportEmail             String   @default("support@polacraft.com")
  gstNumber                String?
  maintenanceMode          Boolean  @default(false)
  
  // Polacraft v1.2 AI Settings
  aiEnabled                Boolean  @default(true)
  aiVisionEnabled          Boolean  @default(true)
  aiMetadataEnabled        Boolean  @default(true)
  aiSocialCaptionsEnabled  Boolean  @default(true)
  aiDefaultTone            String   @default("Collector Focused")
  aiDefaultLanguage        String   @default("English")
  aiMaxDescriptionLength   Int      @default(120)

  updatedAt                DateTime @updatedAt

  @@map("site_settings")
}

model LoyaltyTransaction {
  id          String                 @id @default(uuid())
  userId      String
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  points      Int
  type        LoyaltyTransactionType @default(EARNED)
  description String
  createdAt   DateTime               @default(now())

  @@map("loyalty_transactions")
}

model Promotion {
  id                       String    @id @default(uuid())
  name                     String
  startDate                DateTime
  endDate                  DateTime
  isActive                 Boolean   @default(true)
  freeShippingThreshold    Float?
  collectorRewardThreshold Float?
  premiumRewardThreshold   Float?
  bannerText               String?
  createdAt                DateTime  @default(now())

  @@map("promotions")
}

model AnalyticsEvent {
  id         String   @id @default(uuid())
  type       String   // "Product Viewed", "Search", "Wishlist", "Checkout", "Purchase"
  userId     String?
  sessionId  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@map("analytics_events")
}

model JournalPost {
  id          String        @id @default(uuid())
  slug        String        @unique
  title       String
  excerpt     String
  content     String        @db.Text
  img         String
  readTime    String
  publishedAt DateTime?
  authorId    String
  author      Author        @relation(fields: [authorId], references: [id])
  categoryId  String
  category    BlogCategory  @relation(fields: [categoryId], references: [id])
  tags        Tag[]

  @@map("journal_posts")
}

model Author {
  id        String        @id @default(uuid())
  name      String
  avatar    String?
  posts     JournalPost[]

  @@map("authors")
}

model BlogCategory {
  id        String        @id @default(uuid())
  name      String        @unique
  posts     JournalPost[]

  @@map("blog_categories")
}

model Tag {
  id        String        @id @default(uuid())
  name      String        @unique
  posts     JournalPost[]

  @@map("tags")
}
